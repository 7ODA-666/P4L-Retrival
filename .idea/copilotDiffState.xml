              <option name="updatedContent" value="{% extends &quot;base.html&quot; %}&#10;&#10;{% block title %}P4L Retrieval | Information Retrieval{% endblock %}&#10;&#10;{% block content %}&#10;&lt;link rel=&quot;stylesheet&quot; href=&quot;{{ url_for('static', filename='css/retrieval.css') }}&quot;&gt;&#10;&#10;&lt;div class=&quot;mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 retrieval-container&quot;&gt;&#10;  &#10;  &lt;!-- LEFT SIDE: control panel card --&gt;&#10;  &lt;aside class=&quot;left-panel glass-card p-6&quot;&gt;&#10;    &lt;h2 class=&quot;text-xl font-bold mb-5 text-white&quot;&gt;Retrieval Setup&lt;/h2&gt;&#10;    &#10;    &lt;!-- 1. MULTIPLE FILE UPLOAD --&gt;&#10;    &lt;div class=&quot;mb-5&quot;&gt;&#10;      &lt;label class=&quot;block text-sm font-medium text-slate-300 mb-2&quot;&gt;Upload Documents&lt;/label&gt;&#10;      &lt;div class=&quot;border-2 border-dashed border-slate-600 rounded-lg p-4 text-center hover:border-cyan-400 transition-colors cursor-pointer relative&quot;&gt;&#10;        &lt;input type=&quot;file&quot; id=&quot;fileUpload&quot; multiple accept=&quot;.txt,.pdf&quot; class=&quot;absolute inset-0 w-full h-full opacity-0 cursor-pointer&quot; /&gt;&#10;        &lt;i class=&quot;fa-solid fa-cloud-arrow-up text-3xl text-cyan-500 mb-2&quot;&gt;&lt;/i&gt;&#10;        &lt;p class=&quot;text-sm text-slate-300&quot;&gt;Drag &amp; drop or click to upload&lt;/p&gt;&#10;        &lt;p class=&quot;text-xs text-slate-500 mt-1&quot;&gt;PDF, TXT supported&lt;/p&gt;&#10;      &lt;/div&gt;&#10;    &lt;/div&gt;&#10;    &#10;    &lt;!-- 2. FILE LIST --&gt;&#10;    &lt;div id=&quot;fileList&quot; class=&quot;mb-5 max-h-48 overflow-y-auto pr-2&quot;&gt;&#10;      &lt;!-- Uploaded files will appear here --&gt;&#10;    &lt;/div&gt;&#10;    &#10;    &lt;!-- 3. ALGORITHM SELECT --&gt;&#10;    &lt;div class=&quot;mb-6&quot;&gt;&#10;      &lt;label class=&quot;block text-sm font-medium text-slate-300 mb-2&quot;&gt;Retrieval Algorithm&lt;/label&gt;&#10;      &lt;select id=&quot;algoSelect&quot; class=&quot;w-full bg-slate-900 border border-slate-700 rounded-md py-2 px-3 text-sm text-white focus:outline-none focus:border-cyan-500&quot;&gt;&#10;        &lt;option value=&quot;tdm&quot;&gt;Term Document Matrix&lt;/option&gt;&#10;        &lt;option value=&quot;inverted&quot; disabled&gt;Inverted Index (Soon)&lt;/option&gt;&#10;        &lt;option value=&quot;bow&quot; disabled&gt;Bag of Words (Soon)&lt;/option&gt;&#10;        &lt;option value=&quot;tfidf&quot; disabled&gt;TF-IDF Weight Matrix (Soon)&lt;/option&gt;&#10;      &lt;/select&gt;&#10;    &lt;/div&gt;&#10;    &#10;    &lt;!-- 4. BUTTONS --&gt;&#10;    &lt;div class=&quot;flex flex-col gap-3&quot;&gt;&#10;      &lt;button id=&quot;prepareBtn&quot; class=&quot;primary-btn w-full justify-center&quot;&gt;Start Preparing&lt;/button&gt;&#10;      &lt;button id=&quot;clearBtn&quot; class=&quot;secondary-btn w-full justify-center text-red-400 border-red-900 hover:bg-red-900/20&quot;&gt;Clear Files&lt;/button&gt;&#10;    &lt;/div&gt;&#10;  &lt;/aside&gt;&#10;&#10;  &lt;!-- RIGHT SIDE: workspace card --&gt;&#10;  &lt;main class=&quot;right-panel glass-card p-6 min-h-[500px]&quot;&gt;&#10;    &#10;    &lt;!-- Tabs Header --&gt;&#10;    &lt;div class=&quot;tab-nav&quot;&gt;&#10;      &lt;button class=&quot;tab-btn active&quot; data-target=&quot;tab-visual&quot;&gt;Visualization&lt;/button&gt;&#10;      &lt;button class=&quot;tab-btn&quot; data-target=&quot;tab-search&quot;&gt;Search&lt;/button&gt;&#10;      &lt;button class=&quot;tab-btn&quot; data-target=&quot;tab-about&quot;&gt;About&lt;/button&gt;&#10;    &lt;/div&gt;&#10;    &#10;    &lt;!-- Tab 1: Visualization --&gt;&#10;    &lt;div id=&quot;tab-visual&quot; class=&quot;tab-content active&quot;&gt;&#10;      &lt;div id=&quot;v-success&quot; class=&quot;hidden mb-6 p-4 bg-green-900/30 border border-green-500/50 rounded-lg text-green-300 font-medium flex items-center gap-3&quot;&gt;&#10;        &lt;i class=&quot;fa-soli