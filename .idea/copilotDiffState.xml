cy of terms that occur in a collection of documents. In this boolean model, we indicate the presence or absence of a term with a 1 or 0.&lt;/p&gt;&#10;        &lt;p class=&quot;mb-2 font-bold text-cyan-300&quot;&gt;Preprocessing Importance:&lt;/p&gt;&#10;        &lt;p class=&quot;text-slate-300 text-sm&quot;&gt;Tokenization, stop-word removal, and lemmatization reduce the vocabulary size and group similar words together, improving retrieval accuracy and efficiency.&lt;/p&gt;&#10;      &lt;/div&gt;&#10;      &#10;      &lt;div class=&quot;mb-6 border border-slate-700 rounded overflow-hidden&quot;&gt;&#10;         &lt;!-- Dummy video placeholder as requested --&gt;&#10;         &lt;div class=&quot;bg-black aspect-video flex items-center justify-center text-slate-600&quot;&gt;&#10;            &lt;i class=&quot;fa-brands fa-youtube text-6xl opacity-50&quot;&gt;&lt;/i&gt;&#10;         &lt;/div&gt;&#10;      &lt;/div&gt;&#10;      &#10;      &lt;div&gt;&#10;        &lt;h4 class=&quot;font-bold mb-2 text-purple-300&quot;&gt;Example Matrix&lt;/h4&gt;&#10;        &lt;p class=&quot;text-sm text-slate-400 mb-2&quot;&gt;Doc1: &quot;information retrieval&quot; | Doc2: &quot;retrieval systems&quot;&lt;/p&gt;&#10;        &lt;table class=&quot;w-full text-left text-sm&quot;&gt;&#10;          &lt;thead class=&quot;bg-slate-800&quot;&gt;&#10;            &lt;tr&gt;&#10;              &lt;th class=&quot;p-2&quot;&gt;Term&lt;/th&gt;&lt;th class=&quot;p-2&quot;&gt;Doc 1&lt;/th&gt;&lt;th class=&quot;p-2&quot;&gt;Doc 2&lt;/th&gt;&#10;            &lt;/tr&gt;&#10;          &lt;/thead&gt;&#10;          &lt;tbody class=&quot;divide-y divide-slate-800&quot;&gt;&#10;            &lt;tr&gt;&lt;td class=&quot;p-2&quot;&gt;information&lt;/td&gt;&lt;td class=&quot;p-2&quot;&gt;1&lt;/td&gt;&lt;td class=&quot;p-2&quot;&gt;0&lt;/td&gt;&lt;/tr&gt;&#10;            &lt;tr&gt;&lt;td class=&quot;p-2&quot;&gt;retrieval&lt;/td&gt;&lt;td class=&quot;p-2&quot;&gt;1&lt;/td&gt;&lt;td class=&quot;p-2&quot;&gt;1&lt;/td&gt;&lt;/tr&gt;&#10;            &lt;tr&gt;&lt;td class=&quot;p-2&quot;&gt;systems&lt;/td&gt;&lt;td class=&quot;p-2&quot;&gt;0&lt;/td&gt;&lt;td class=&quot;p-2&quot;&gt;1&lt;/td&gt;&lt;/tr&gt;&#10;          &lt;/tbody&gt;&#10;        &lt;/table&gt;&#10;      &lt;/div&gt;&#10;    &lt;/div&gt;&#10;    &#10;  &lt;/main&gt;&#10;&lt;/div&gt;&#10;&#10;&lt;!-- Modal Popup for Document Preview --&gt;&#10;&lt;div id=&quot;docModal&quot; class=&quot;modal-overlay&quot;&gt;&#10;  &lt;div class=&quot;modal-content&quot;&gt;&#10;    &lt;div class=&quot;modal-header&quot;&gt;&#10;      &lt;h3 id=&quot;modalTitle&quot; class=&quot;text-xl font-bold text-cyan-300&quot;&gt;Document Title&lt;/h3&gt;&#10;      &lt;button id=&quot;closeModal&quot; class=&quot;text-slate-400 hover:text-white transition-colors&quot;&gt;&#10;        &lt;i class=&quot;fa-solid fa-xmark text-xl&quot;&gt;&lt;/i&gt;&#10;      &lt;/button&gt;&#10;    &lt;/div&gt;&#10;    &lt;div id=&quot;modalBody&quot; class=&quot;modal-body text-slate-300&quot;&gt;&#10;      &lt;!-- Content here --&gt;&#10;    &lt;/div&gt;&#10;  &lt;/div&gt;&#10;&lt;/div&gt;&#10;&#10;&lt;script src=&quot;{{ url_for('static', filename='js/retrieval.js') }}&quot;&gt;&lt;/script&gt;&#10;{% endblock %}" />
